# Скопируйте в .env и заполните своими значениями

# Входящий вебхук Битрикс24 (Разработчикам → Входящий вебхук, права CRM)
BITRIX_WEBHOOK_URL=

# Токен для чтения лидов и событий (придумайте длинную случайную строку)
ADMIN_TOKEN=

# База данных (по умолчанию SQLite-файл рядом с backend/)
DATABASE_URL=sqlite:///./ecs.db

# Адреса фронтенда через запятую (JSON-список)
CORS_ORIGINS=["http://localhost:8765","http://127.0.0.1:8765"]
